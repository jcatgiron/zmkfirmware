#include "go60.dtsi"

/ {
    chosen {
        zmk,matrix_transform = &default_transform;
        zmk,kscan = &kscan0;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        row-gpios = <&gpio0 0 &gpio0 1 &gpio0 2 &gpio0 3 &gpio0 4>;
        col-gpios = <&gpio1 0 &gpio1 1 &gpio1 2 &gpio1 3 &gpio1 4 &gpio1 5>;
        debounce-press-ms = <5>;
        debounce-release-ms = <5>;
    };
};
